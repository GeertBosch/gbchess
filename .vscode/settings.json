{
    "makefile.configureOnOpen": false,
    "clangd.fallbackFlags": [
        "-Wextra",
        "-Wall",
        "-Werror",
        "-std=c++20"
    ],
    "files.associations": {
        "*.mmd": "mermaid"
    },
    "[c]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "editor.formatOnSave": true
    },
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "editor.formatOnSave": true
    }
}
